{
  "schemaVersion": "app.0.1",
  "id": "com.haas.media-server",
  "name": "Media Server",
  "description": "Self-hosted media server: torrent ingest, automatic organize/identify/probe, and a Jellyfin-compatible streaming surface for native clients (Infuse).",
  "version": "0.21.0",
  "runtimeProfiles": [
    { "key": "docker", "type": "docker", "default": true },
    { "key": "dev", "type": "localCommand" }
  ],
  "defaultRuntime": "docker",
  "services": [
    {
      "key": "api",
      "runtimes": {
        "docker": {
          "type": "docker",
          "image": { "repository": "ghcr.io/alex-de-haas/media-server-api", "tag": "latest", "pullPolicy": "always" },
          "ports": [
            { "key": "internal", "containerPort": 8080, "protocol": "http" },
            { "key": "jellyfin", "containerPort": 8096, "protocol": "http", "public": true }
          ]
        },
        "dev": {
          "type": "localCommand",
          "workingDirectory": "src/api",
          "command": "dotnet run --project MediaServer.Api",
          "ports": [
            { "key": "internal", "containerPort": 8080, "protocol": "http" },
            { "key": "jellyfin", "containerPort": 8096, "protocol": "http", "public": true }
          ]
        }
      }
    },
    {
      "key": "web",
      "dependsOn": ["api"],
      "runtimes": {
        "docker": {
          "type": "docker",
          "image": { "repository": "ghcr.io/alex-de-haas/media-server-web", "tag": "latest", "pullPolicy": "always" },
          "ports": [
            { "key": "http", "containerPort": 3000, "protocol": "http", "public": true }
          ]
        },
        "dev": {
          "type": "localCommand",
          "workingDirectory": "src/web",
          "command": "pnpm dev",
          "ports": [
            { "key": "http", "containerPort": 3000, "protocol": "http", "public": true }
          ]
        }
      }
    }
  ],
  "endpoints": [
    { "key": "ui", "service": "web", "port": "http", "protocol": "http", "public": true },
    { "key": "jellyfin", "service": "api", "port": "jellyfin", "protocol": "http", "public": true }
  ],
  "dependencies": [
    { "id": "com.haas.torrent-engine", "required": true, "endpoints": [{ "key": "control", "as": "torrent-engine" }] },
    { "id": "com.haas.transcode-engine", "required": false, "endpoints": [{ "key": "control", "as": "transcode-engine" }] }
  ],
  "ui": {
    "entrypoint": { "endpoint": "ui", "path": "/" },
    "navigation": [
      { "label": "Home", "path": "/", "iconAsset": "assets/nav/home.svg" },
      { "label": "Movies", "path": "/movies", "iconAsset": "assets/nav/movies.svg" },
      { "label": "Series", "path": "/series", "iconAsset": "assets/nav/series.svg" },
      { "label": "Collections", "path": "/collections", "iconAsset": "assets/nav/collections.svg" },
      { "label": "Calendar", "path": "/calendar", "iconAsset": "assets/nav/calendar.svg" },
      { "label": "Activity", "path": "/activity", "iconAsset": "assets/nav/activity.svg" },
      { "label": "Catalogs", "path": "/catalogs", "iconAsset": "assets/nav/catalogs.svg" },
      { "label": "Settings", "path": "/settings", "iconAsset": "assets/nav/settings.svg" }
    ]
  },
  "data": {
    "enabled": true,
    "targets": [
      { "runtime": "docker", "service": "api", "containerPath": "/app/data", "environment": "HOSTY_APP_DATA_DIR" },
      { "runtime": "dev", "environment": "HOSTY_APP_DATA_DIR" }
    ]
  },
  "externalMounts": {
    "catalogRoots": { "kind": "host-path", "multiple": true, "mode": "rw", "service": "api", "required": true }
  },
  "settings": [
    {
      "key": "TMDB_API_KEY",
      "type": "string",
      "secret": true,
      "required": true,
      "label": "TMDb API key",
      "description": "API key for The Movie Database, used to identify and fetch metadata for your media."
    },
    {
      "key": "SUPPORTED_LANGUAGES",
      "type": "string",
      "default": "en-US",
      "label": "Supported languages",
      "description": "Comma-separated metadata languages in priority order; the first is the fallback (e.g. en-US,ru-RU)."
    },
    {
      "key": "WATCH_REGION",
      "type": "string",
      "default": "US",
      "label": "Watch region",
      "description": "ISO-3166-1 country whose release dates the calendar tracks (e.g. US, RU). Independent of the metadata languages; per-title overrides are available on the watchlist."
    },
    {
      "key": "JELLYFIN_SERVER_NAME",
      "type": "string",
      "default": "Media Server",
      "label": "Jellyfin server name",
      "description": "Server name advertised to Jellyfin-compatible clients such as Infuse."
    },
    {
      "key": "JELLYFIN_DISCOVERY_ENABLED",
      "type": "boolean",
      "default": "false",
      "label": "Jellyfin auto-discovery",
      "description": "Broadcast the server on the local network so Jellyfin clients can find it automatically."
    },
    {
      "key": "PLAYBACK_DIAGNOSTICS",
      "type": "boolean",
      "default": "false",
      "label": "Playback diagnostics",
      "description": "Log every playback-state request from clients like Infuse to logs/playback-diagnostics.log, for investigating watched-state behaviour. Records ids, positions and flags only - no titles, paths or tokens. Leave off for normal use."
    },
    {
      "key": "FFPROBE_PATH",
      "type": "string",
      "label": "ffprobe path",
      "description": "Override path to the ffprobe binary. Leave empty to use the one found on PATH."
    },
    {
      "key": "FFMPEG_PATH",
      "type": "string",
      "label": "ffmpeg path",
      "description": "Override path to the ffmpeg binary, used to merge external audio tracks into their videos during ingest. Leave empty to use the one found on PATH."
    },
    {
      "key": "TORRENT_MAX_DOWNLOAD_SPEED",
      "type": "number",
      "default": "0",
      "label": "Max download speed (bytes/s)",
      "description": "Per-download rate limit forwarded to the torrent engine, in bytes per second. 0 means unlimited."
    },
    {
      "key": "TORRENT_MAX_UPLOAD_SPEED",
      "type": "number",
      "default": "0",
      "label": "Max upload speed (bytes/s)",
      "description": "Per-download upload rate limit forwarded to the torrent engine, in bytes per second. 0 means unlimited."
    }
  ],
  "telemetry": { "enabled": true, "sampleRatio": 0.1 },
  "capabilities": ["backup", "logs"],
  "catalogMetadata": {
    "publisher": {
      "name": "Haas",
      "url": "https://github.com/alex-de-haas",
      "email": "a.zayats@outlook.com"
    },
    "category": "Media",
    "tags": ["media", "streaming", "jellyfin", "movies", "tv"],
    "icon": "assets/icon.svg",
    "license": "AGPL-3.0-only",
    "links": {
      "website": "https://github.com/alex-de-haas/media-server",
      "docs": "https://github.com/alex-de-haas/media-server/blob/main/docs/root.md"
    },
    "summary": "Self-hosted media server with torrent ingest, auto-organize, and a Jellyfin-compatible surface.",
    "descriptionFile": "docs/store.md"
  }
}
